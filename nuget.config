<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="local-sharpastro" value="../DIR.Lib/src/DIR.Lib/bin/Release" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="local-sharpastro">
      <package pattern="DIR.Lib" />
    </packageSource>
  </packageSourceMapping>
</configuration>
